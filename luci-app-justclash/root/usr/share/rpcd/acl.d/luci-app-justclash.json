{
    "luci-app-justclash": {
        "description": "Grant UCI and RPC access to LuCI app justclash",
        "read": {
            "file": {
                "/etc/init.d/justclash": [
                    "exec"
                ],
                "/usr/bin/justclash.sh": [
                    "exec"
                ],
                "/etc/justclash/rulesets.txt": [
                    "read"
                ],
                "/etc/justclash/block.rulesets.txt": [
                    "read"
                ],
                "/etc/justclash/user.rulesets.txt": [
                    "read"
                ],
                "/etc/justclash/user.block.rulesets.txt": [
                    "read"
                ]
            },
            "uci": [
                "justclash"
            ],
            "ubus": {
                "system": [
                    "board"
                ],
                "service": [
                    "list"
                ],
                "luci": [
                    "getInitList"
                ]
            }
        },
        "write": {
            "file": {
                "/etc/justclash/user.rulesets.txt": [
                    "write"
                ],
                "/etc/justclash/user.block.rulesets.txt": [
                    "write"
                ]
            },
            "uci": [
                "justclash"
            ]
        }
    }
}