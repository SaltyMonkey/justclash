#: htdocs/luci-static/resources/view/justclash/proxy.js:59
msgid "Proxy settings"
msgstr "Настройки прокси"

#: htdocs/luci-static/resources/view/justclash/proxy.js:59
msgid "Main proxy settings used by Mihomo."
msgstr "Основные настройки прокси, которые использует Mihomo."

#: htdocs/luci-static/resources/view/justclash/proxy.js:62
msgid "Basic settings"
msgstr "Базовые настройки"

#: htdocs/luci-static/resources/view/justclash/proxy.js:64
msgid "Logging level:"
msgstr "Уровень логов:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:68
msgid "Choose how much information Mihomo writes to the log. Higher levels help with debugging, but create more log entries."
msgstr "Выберите, сколько информации Mihomo будет записывать в журнал. Более подробные уровни помогают в диагностике, но создают больше записей."

#: htdocs/luci-static/resources/view/justclash/proxy.js:72
msgid "Bind all outbound connections to interface:"
msgstr "Исходящий интерфейс:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:73
msgid "Bind Mihomo outbound connections to a specific network device by default. Leave empty to let the system choose the outgoing interface. Per-proxy and per-provider interface settings should override this value when set."
msgstr "По умолчанию привязать исходящие подключения Mihomo к выбранному сетевому устройству. Оставьте поле пустым, чтобы система сама выбрала исходящий интерфейс. Настройки интерфейса в отдельных прокси и провайдерах должны переопределять это значение."

#: htdocs/luci-static/resources/view/justclash/proxy.js:81
msgid "Transparent proxy port:"
msgstr "Порт прозрачного прокси:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:82
msgid "Port used for redirected TCP/UDP traffic. Change it only if this port is already used by another service."
msgstr "Порт для перенаправленного TCP/UDP-трафика. Меняйте его только если этот порт уже занят другим сервисом."

#: htdocs/luci-static/resources/view/justclash/proxy.js:88
msgid "Enable Mihomo mixed port:"
msgstr "Включить mixed port:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:89
msgid "Use the Mihomo mixed port so one port handles both HTTP(S) and SOCKS5 connections. This is useful when apps or devices connect to the router as a regular proxy."
msgstr "Использовать mixed port Mihomo, чтобы один порт обслуживал и HTTP(S), и SOCKS5-подключения. Это удобно, если приложения или устройства подключаются к роутеру как к обычному прокси."

#: htdocs/luci-static/resources/view/justclash/proxy.js:93
msgid "Mihomo mixed port:"
msgstr "Mihomo mixed port:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:94
msgid "Port used by the Mihomo mixed port listener for both HTTP(S) and SOCKS5 connections from apps and devices on your network."
msgstr "Порт слушателя Mihomo mixed port для HTTP(S) и SOCKS5-подключений от приложений и устройств в вашей сети."

#: htdocs/luci-static/resources/view/justclash/proxy.js:102
msgid "Mixed port authentication:"
msgstr "Аутентификация mixed port:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:103
msgid "Require username and password for access to the Mihomo mixed port. Add one entry per line in the format user:pass."
msgstr "Требовать имя пользователя и пароль для доступа к mixed port Mihomo. Добавляйте по одной записи в формате user:pass."

#: htdocs/luci-static/resources/view/justclash/proxy.js:112
msgid "Unified delay:"
msgstr "Единая задержка:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:113
msgid "Use the same delay value when checking response time, so test results stay more consistent."
msgstr "Использовать одинаковое значение задержки при проверке отклика, чтобы результаты тестов были более стабильными."

#: htdocs/luci-static/resources/view/justclash/proxy.js:117
msgid "Try TCP connections in parallel:"
msgstr "Параллельный TCP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:118
msgid "Try several TCP connections at the same time. This can help on unstable networks, but it may create extra connection attempts."
msgstr "Пробовать несколько TCP-подключений одновременно. Это может помочь в нестабильной сети, но создаёт дополнительные попытки подключения."

#: htdocs/luci-static/resources/view/justclash/proxy.js:122
msgid "User-Agent for downloads:"
msgstr "User-Agent для загрузок:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:123
msgid "User-Agent sent when downloading external files such as subscriptions or rule lists."
msgstr "Как сервис будет представляться при загрузке внешних файлов, например подписок и списков правил."

#: htdocs/luci-static/resources/view/justclash/proxy.js:127
msgid "Check whether files changed:"
msgstr "Проверять изменения файлов:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:128
msgid "Only download external files again when the server says they changed. This saves bandwidth and avoids unnecessary updates."
msgstr "Скачивать внешние файлы заново только если сервер сообщает об изменениях. Это экономит трафик и уменьшает число лишних обновлений."

#: htdocs/luci-static/resources/view/justclash/proxy.js:132
msgid "Idle time before connection check:"
msgstr "Простой до проверки соединения:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:133
msgid "How long to wait with no activity before checking whether the connection is still alive. Shorter values detect dead connections sooner."
msgstr "Сколько ждать без обмена данными перед проверкой соединения. Меньшие значения быстрее обнаруживают разрыв."

#: htdocs/luci-static/resources/view/justclash/proxy.js:144
msgid "Connection check interval:"
msgstr "Интервал проверки соединения:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:145
msgid "How often to repeat that check after the connection becomes idle."
msgstr "Как часто повторять такую проверку после простоя."

#: htdocs/luci-static/resources/view/justclash/proxy.js:156
msgid "Save profile data:"
msgstr "Сохранять профиль:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:157
msgid "Keep profile data when possible, so selected items can be restored after a restart."
msgstr "Сохранять данные профиля, чтобы выбранные элементы можно было восстановить после перезапуска."

#: htdocs/luci-static/resources/view/justclash/proxy.js:161
msgid "Save fake IP addresses:"
msgstr "Сохранять адреса Fake IP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:162
msgid "Keep assigned fake IP addresses when possible, which can reduce repeated DNS work after restarts."
msgstr "Сохранять выданные подменные IP-адреса, чтобы после перезапуска реже выполнять повторные DNS-запросы."

#: htdocs/luci-static/resources/view/justclash/proxy.js:167
