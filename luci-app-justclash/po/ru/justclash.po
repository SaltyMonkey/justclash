msgstr "Основные DNS-серверы, используемые для обычных DNS-запросов."

#: htdocs/luci-static/resources/view/justclash/proxy.js:339
msgid "Force real IP rulesets:"
msgstr "Принудительные ruleset'ы для real IP:"

