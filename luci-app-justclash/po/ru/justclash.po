msgstr "Поле Name не должно быть определено в объекте."

#: htdocs/luci-static/resources/view/justclash/helper_common.js:583
msgid "DIRECT proxy type must be defined without server or port fields."
msgstr "Тип прокси DIRECT должен быть определен без полей server или port."

