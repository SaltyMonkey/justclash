#: htdocs/luci-static/resources/view/justclash/proxy.js:39
msgid "Proxy settings"
msgstr "Настройки прокси"

#: htdocs/luci-static/resources/view/justclash/proxy.js:39
msgid "Main proxy settings used by Mihomo."
msgstr "Основные настройки прокси, которые использует Mihomo."

#: htdocs/luci-static/resources/view/justclash/proxy.js:42
msgid "Basic settings"
msgstr "Базовые настройки"

#: htdocs/luci-static/resources/view/justclash/proxy.js:44
msgid "Logging level:"
msgstr "Уровень логов:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:48
msgid "Choose how much information Mihomo writes to the log. Higher levels help with debugging, but create more log entries."
msgstr "Выберите, сколько информации Mihomo будет записывать в журнал. Более подробные уровни помогают в диагностике, но создают больше записей."

#: htdocs/luci-static/resources/view/justclash/proxy.js:52
msgid "Bind all outbound connections to interface:"
msgstr "Исходящий интерфейс:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:53
msgid "Bind Mihomo outbound connections to a specific network device by default. Leave empty to let the system choose the outgoing interface. Per-proxy and per-provider interface settings should override this value when set."
msgstr "По умолчанию привязать исходящие подключения Mihomo к выбранному сетевому устройству. Оставьте поле пустым, чтобы система сама выбрала исходящий интерфейс. Настройки интерфейса в отдельных прокси и провайдерах должны переопределять это значение."

#: htdocs/luci-static/resources/view/justclash/proxy.js:61
msgid "Transparent proxy port:"
msgstr "Порт прозрачного прокси:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:62
msgid "Port used for redirected TCP/UDP traffic. Change it only if this port is already used by another service."
msgstr "Порт для перенаправленного TCP/UDP-трафика. Меняйте его только если этот порт уже занят другим сервисом."

#: htdocs/luci-static/resources/view/justclash/proxy.js:68
msgid "Enable Mihomo mixed port:"
msgstr "Включить mixed port:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:69
msgid "Use the Mihomo mixed port so one port handles both HTTP(S) and SOCKS5 connections. This is useful when apps or devices connect to the router as a regular proxy."
msgstr "Использовать mixed port Mihomo, чтобы один порт обслуживал и HTTP(S), и SOCKS5-подключения. Это удобно, если приложения или устройства подключаются к роутеру как к обычному прокси."

#: htdocs/luci-static/resources/view/justclash/proxy.js:73
msgid "Mihomo mixed port:"
msgstr "Mihomo mixed port:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:74
msgid "Port used by the Mihomo mixed port listener for both HTTP(S) and SOCKS5 connections from apps and devices on your network."
msgstr "Порт слушателя Mihomo mixed port для HTTP(S) и SOCKS5-подключений от приложений и устройств в вашей сети."

#: htdocs/luci-static/resources/view/justclash/proxy.js:82
msgid "Mixed port authentication:"
msgstr "Аутентификация mixed port:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:83
msgid "Require username and password for access to the Mihomo mixed port. Add one entry per line in the format user:pass."
msgstr "Требовать имя пользователя и пароль для доступа к mixed port Mihomo. Добавляйте по одной записи в формате user:pass."

#: htdocs/luci-static/resources/view/justclash/proxy.js:92
msgid "Unified delay:"
msgstr "Единая задержка:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:93
msgid "Use the same delay value when checking response time, so test results stay more consistent."
msgstr "Использовать одинаковое значение задержки при проверке отклика, чтобы результаты тестов были более стабильными."

#: htdocs/luci-static/resources/view/justclash/proxy.js:97
msgid "Try TCP connections in parallel:"
msgstr "Параллельный TCP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:98
msgid "Try several TCP connections at the same time. This can help on unstable networks, but it may create extra connection attempts."
msgstr "Пробовать несколько TCP-подключений одновременно. Это может помочь в нестабильной сети, но создаёт дополнительные попытки подключения."

#: htdocs/luci-static/resources/view/justclash/proxy.js:102
msgid "Client profile for all connections:"
msgstr "Профиль клиента:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:106
msgid "How the client identifies itself for supported protocols. Leave the default unless your provider expects a specific profile."
msgstr "Как сервис будет представляться в поддерживаемых протоколах. Оставьте значение по умолчанию, если провайдер не требует другой профиль."

#: htdocs/luci-static/resources/view/justclash/proxy.js:110
msgid "User-Agent for downloads:"
msgstr "User-Agent для загрузок:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:111
msgid "User-Agent sent when downloading external files such as subscriptions or rule lists."
msgstr "Как сервис будет представляться при загрузке внешних файлов, например подписок и списков правил."

#: htdocs/luci-static/resources/view/justclash/proxy.js:115
msgid "Check whether files changed:"
msgstr "Проверять изменения файлов:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:116
msgid "Only download external files again when the server says they changed. This saves bandwidth and avoids unnecessary updates."
msgstr "Скачивать внешние файлы заново только если сервер сообщает об изменениях. Это экономит трафик и уменьшает число лишних обновлений."

#: htdocs/luci-static/resources/view/justclash/proxy.js:120
msgid "Idle time before connection check:"
msgstr "Простой до проверки соединения:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:121
msgid "How long to wait with no activity before checking whether the connection is still alive. Shorter values detect dead connections sooner."
msgstr "Сколько ждать без обмена данными перед проверкой соединения. Меньшие значения быстрее обнаруживают разрыв."

#: htdocs/luci-static/resources/view/justclash/proxy.js:132
msgid "Connection check interval:"
msgstr "Интервал проверки соединения:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:133
msgid "How often to repeat that check after the connection becomes idle."
msgstr "Как часто повторять такую проверку после простоя."

#: htdocs/luci-static/resources/view/justclash/proxy.js:144
msgid "Save profile data:"
msgstr "Сохранять профиль:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:145
msgid "Keep profile data when possible, so selected items can be restored after a restart."
msgstr "Сохранять данные профиля, чтобы выбранные элементы можно было восстановить после перезапуска."

#: htdocs/luci-static/resources/view/justclash/proxy.js:149
msgid "Save fake IP addresses:"
msgstr "Сохранять адреса Fake IP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:150
msgid "Keep assigned fake IP addresses when possible, which can reduce repeated DNS work after restarts."
msgstr "Сохранять выданные подменные IP-адреса, чтобы после перезапуска реже выполнять повторные DNS-запросы."

#: htdocs/luci-static/resources/view/justclash/proxy.js:155
msgid "Controller/API settings"
msgstr "Настройки API"

#: htdocs/luci-static/resources/view/justclash/proxy.js:158
msgid "Controller bind:"
msgstr "Интерфейс API:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:158 htdocs/luci-static/resources/view/justclash/proxy.js:163
msgid "Select which network will allow access to the API controller and dashboard."
msgstr "Выберите сеть, из которой будет доступен API-контроллер и панель управления."

#: htdocs/luci-static/resources/view/justclash/proxy.js:165
msgid "Enable dashboard:"
msgstr "Включить дашборд:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:166
msgid "Enable an additional external web dashboard for Mihomo. Turn this on only if you need a separate dashboard interface."
msgstr "Включить веб-панель Mihomo. Используйте это только если вам нужен доступ к панели."

#: htdocs/luci-static/resources/view/justclash/proxy.js:175
msgid "Web dashboard:"
msgstr "Дашборд:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:176
msgid "Choose which web dashboard Mihomo should download and serve."
msgstr "Выберите, какой web-дашборд Mihomo должен скачивать и отдавать."

#: htdocs/luci-static/resources/view/justclash/proxy.js:177
msgid "zashboard"
msgstr "zashboard"

#: htdocs/luci-static/resources/view/justclash/proxy.js:178
msgid "metacubexd"
msgstr "metacubexd"

#: htdocs/luci-static/resources/view/justclash/proxy.js:179
msgid "Yacd-meta"
msgstr "Yacd-meta"

#: htdocs/luci-static/resources/view/justclash/proxy.js:185
msgid "API password:"
msgstr "API пароль:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:187
msgid "Password or token required to access the API controller."
msgstr "Пароль или токен для доступа к API-контроллеру."

#: htdocs/luci-static/resources/view/justclash/proxy.js:194
msgid "DNS settings"
msgstr "Настройки DNS"

#: htdocs/luci-static/resources/view/justclash/proxy.js:196
msgid "DNS listen port:"
msgstr "DNS-порт:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:197
msgid "Port where Mihomo built-in DNS server listens."
msgstr "Порт, на котором встроенный DNS-сервер Mihomo принимает запросы."

#: htdocs/luci-static/resources/view/justclash/proxy.js:203
msgid "Use system hosts:"
msgstr "Hosts из системы:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:204
msgid "Load DNS entries from the system hosts file when possible."
msgstr "Загружать DNS-записи из системного файла hosts, когда это возможно."

#: htdocs/luci-static/resources/view/justclash/proxy.js:208
msgid "DNS cache size:"
msgstr "Кэш DNS:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:209
msgid "Maximum number of DNS cache entries kept by Mihomo."
msgstr "Максимальное количество DNS-записей, которое Mihomo хранит в кэше."

#: htdocs/luci-static/resources/view/justclash/proxy.js:220
msgid "Fake IP range:"
msgstr "Диапазон Fake IP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:221
msgid "IPv4 CIDR range used for fake-IP responses."
msgstr "Диапазон IPv4 CIDR, который используется для fake-IP ответов."

#: htdocs/luci-static/resources/view/justclash/proxy.js:227
msgid "Fake IP TTL:"
msgstr "TTL Fake IP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:228
msgid "TTL for fake-IP DNS responses."
msgstr "TTL для DNS-ответов с fake-IP."

#: htdocs/luci-static/resources/view/justclash/proxy.js:239
msgid "Nameserver policy:"
msgstr "DNS-политика:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:240
msgid "Domain-specific DNS policy in the format domain/nameserver (example: +.arpa/10.0.0.1)."
msgstr "Политика DNS для доменов в формате domain/nameserver (пример: +.arpa/10.0.0.1)."

#: htdocs/luci-static/resources/view/justclash/proxy.js:247
msgid "Default nameservers:"
msgstr "DNS по умолчанию:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:248
msgid "Default nameservers used at startup. Recommended to use UDP ones."
msgstr "DNS сервера по умолчанию при запуске. Рекомендуется использовать UDP-серверы."

#: htdocs/luci-static/resources/view/justclash/proxy.js:255
msgid "Direct nameservers:"
msgstr "Прямые DNS:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:256
msgid "Direct nameservers used for DIRECT rules."
msgstr "DNS сервера, используемые для правил прямого соединения."

#: htdocs/luci-static/resources/view/justclash/proxy.js:263
msgid "Proxy nameservers:"
msgstr "DNS для прокси:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:264
msgid "Nameservers used to resolve proxy server hostnames."
msgstr "DNS-серверы, используемые для разрешения имён прокси-серверов."

#: htdocs/luci-static/resources/view/justclash/proxy.js:272
msgid "Nameservers:"
msgstr "DNS-серверы:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:273
msgid "Main nameservers used for regular DNS queries."
msgstr "Основные DNS-серверы, используемые для обычных DNS-запросов."

#: htdocs/luci-static/resources/view/justclash/proxy.js:281
msgid "Force fake IP rulesets:"
msgstr "Принудительные ruleset'ы для fake IP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:285
msgid "Ruleset names that should resolve through fake IP. Values are treated as RULE-SET selectors, for example youtube or custom_domain_list."
msgstr "Имена ruleset'ов, которые должны резолвиться через fake IP. Значения трактуются как селекторы RULE-SET, например youtube или custom_domain_list."

#: htdocs/luci-static/resources/view/justclash/proxy.js:291
msgid "Force real IP rulesets:"
msgstr "Принудительные ruleset'ы для real IP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:295
msgid "Ruleset names that should resolve through real IP before fake-IP matches are applied. Values are treated as RULE-SET selectors, for example youtube or custom_domain_list."
msgstr "Имена ruleset'ов, которые должны резолвиться через real IP до применения fake-IP совпадений. Значения трактуются как селекторы RULE-SET, например youtube или custom_domain_list."

#: htdocs/luci-static/resources/view/justclash/proxy.js:301
msgid "Force fake IP rules:"
msgstr "Принудительные правила fake IP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:302
msgid "Entries that should resolve through fake IP; use plain suffixes like example.com."
msgstr "Записи, которые должны резолвиться через fake IP; используйте обычные суффиксы вроде example.com."

#: htdocs/luci-static/resources/view/justclash/proxy.js:311
msgid "Force real IP rules:"
msgstr "Принудительные правила real IP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:312
msgid "Entries that should resolve through real IP before fake-IP matches are applied; use plain suffixes like example.com."
msgstr "Записи, которые должны резолвиться через real IP до применения fake-IP совпадений; используйте обычные суффиксы вроде example.com."

#: htdocs/luci-static/resources/view/justclash/proxy.js:322
msgid "Sniffer settings"
msgstr "Настройки анализатора"

#: htdocs/luci-static/resources/view/justclash/proxy.js:324
msgid "Enable sniffer:"
msgstr "Включить sniffer:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:325
msgid "Enable Mihomo traffic sniffing."
msgstr "Включить анализ трафика Mihomo."

#: htdocs/luci-static/resources/view/justclash/proxy.js:329
msgid "Parse pure IP:"
msgstr "Анализ IP без домена:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:330
msgid "Force domain detection for traffic without resolved domain names."
msgstr "Принудительно определять домен для трафика без доменного имени."

#: htdocs/luci-static/resources/view/justclash/proxy.js:334
msgid "Excluded from sniffer domains:"
msgstr "Исключить домены из sniffer:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:335
msgid "Domains excluded from detailed analysis when possible. Sometimes this can help with errors in apps."
msgstr "Домены, исключённые из sniffer, если это возможно. Иногда это помогает избежать ошибок в приложениях."

#: htdocs/luci-static/resources/view/justclash/proxy.js:343
msgid "Forcefully sniff domains:"
msgstr "Домены для принудительного анализа:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:344
msgid "Domains included for detailed analysis when possible. Sometimes this can help with errors in apps."
msgstr "Домены, для которых по возможности выполняется принудительный анализ. Иногда это помогает избежать ошибок в приложениях."

#: htdocs/luci-static/resources/view/justclash/proxy.js:352
msgid "Exclude from sniffer SRC CIDR traffic:"
msgstr "Исключить SRC CIDR из sniffer:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:353
msgid "Source address ranges excluded from sniffing."
msgstr "Диапазоны исходных адресов, исключённые из sniffing."

#: htdocs/luci-static/resources/view/justclash/proxy.js:359
msgid "Exclude from sniffer DST CIDR traffic:"
msgstr "Исключить DST CIDR из sniffer:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:360
msgid "Destination address ranges excluded from sniffing."
msgstr "Диапазоны адресов назначения, исключённые из sniffing."

#: htdocs/luci-static/resources/view/justclash/proxy.js:367
msgid "NTP settings"
msgstr "Настройки NTP"

#: htdocs/luci-static/resources/view/justclash/proxy.js:369
msgid "Enable NTP client:"
msgstr "Включить NTP-клиент:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:370
msgid "Enable the built-in Mihomo NTP client."
msgstr "Включить встроенный NTP-клиент Mihomo."

#: htdocs/luci-static/resources/view/justclash/proxy.js:374
msgid "Endpoint NTP server:"
msgstr "NTP-сервер:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:375
msgid "Upstream NTP server used by Mihomo."
msgstr "Вышестоящий NTP-сервер, который использует Mihomo."

#: htdocs/luci-static/resources/view/justclash/proxy.js:383
msgid "NTP port:"
msgstr "Порт NTP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:384
msgid "Upstream NTP server port."
msgstr "Порт вышестоящего NTP-сервера."

#: htdocs/luci-static/resources/view/justclash/proxy.js:388
msgid "NTP check interval:"
msgstr "Интервал проверки NTP:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:389
msgid "How often Mihomo should sync time, in minutes."
msgstr "Как часто Mihomo должен синхронизировать время, в минутах."

#: htdocs/luci-static/resources/view/justclash/proxy.js:400
msgid "Write to system:"
msgstr "Менять системное время:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:401
