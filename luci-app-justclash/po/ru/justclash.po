msgstr "Тип прокси DIRECT должен быть определен без полей server или port."

#: htdocs/luci-static/resources/view/justclash/helper_common.js:589
msgid "JSON must contain at least type, server and port fields."
msgstr "JSON должен содержать как минимум поля type, server и port."

#: htdocs/luci-static/resources/view/justclash/helper_common.js:592
msgid "Proxy type contains unsupported characters"
msgstr "Тип прокси содержит неподдерживаемые символы"

#: htdocs/luci-static/resources/view/justclash/helper_common.js:595
msgid "Server must be a non-empty host without whitespace"
msgstr "Server должен быть непустым хостом без пробелов"

#: htdocs/luci-static/resources/view/justclash/helper_common.js:605
msgid "Only lowercase letters, digits, and the '|' separator are allowed. No spaces or special symbols."
msgstr "Разрешены только строчные буквы, цифры и разделитель '|'. Пробелы и специальные символы запрещены."

#: htdocs/luci-static/resources/view/justclash/helper_common.js:608
