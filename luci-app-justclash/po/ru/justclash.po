msgstr "Между точками не должно быть пустых сегментов"

#: htdocs/luci-static/resources/view/justclash/helper_common.js:489
msgid "Each domain segment must not exceed 63 characters"
msgstr "Каждый сегмент домена не должен превышать 63 символа"

