msgstr "Неверный формат JSON"

#: htdocs/luci-static/resources/view/justclash/helper_common.js:577
msgid "JSON must be an object"
msgstr "JSON должен быть объектом"

#: htdocs/luci-static/resources/view/justclash/helper_common.js:580
