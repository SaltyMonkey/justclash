#: htdocs/luci-static/resources/view/justclash/service.js:27
msgid "Startup"
msgstr "Запуск"

#: htdocs/luci-static/resources/view/justclash/service.js:29
msgid "Wait for WAN connection on boot:"
msgstr "Ожидать подключения к интернету (WAN) при загрузке:"

#: htdocs/luci-static/resources/view/justclash/service.js:30
msgid "Pause the startup process until the router establishes an active Internet connection (default route)."
msgstr "Приостановить процесс запуска до тех пор, пока роутер не установит активное подключение к интернету (маршрут по умолчанию)."

#: htdocs/luci-static/resources/view/justclash/service.js:34
msgid "Maximum wait time for WAN (s):"
msgstr "Максимальное время ожидания WAN (сек):"

#: htdocs/luci-static/resources/view/justclash/service.js:42
msgid "Maximum time in seconds to wait for WAN connection before proceeding with the current state."
msgstr "Максимальное время в секундах для ожидания подключения, прежде чем запуск продолжится в любом случае."

#: htdocs/luci-static/resources/view/justclash/service.js:45
msgid "Delay startup after boot:"
msgstr "Задержка после старта:"

#: htdocs/luci-static/resources/view/justclash/service.js:46
msgid "Start the service a little later after the router boots. Useful if the router needs extra time to bring up storage, WAN, or other services."
msgstr "Запускать сервис чуть позже после включения роутера. Полезно, если устройству нужно больше времени для поднятия сети, накопителей или других служб."

#: htdocs/luci-static/resources/view/justclash/service.js:50
msgid "Startup delay:"
msgstr "Задержка запуска:"

#: htdocs/luci-static/resources/view/justclash/service.js:60
msgid "Choose how many seconds to wait before the first service start after boot."
msgstr "Выберите, сколько секунд ждать до первого запуска сервиса после включения."

#: htdocs/luci-static/resources/view/justclash/service.js:62
msgid "Skip startup checks:"
msgstr "Без проверок при запуске:"

#: htdocs/luci-static/resources/view/justclash/service.js:63
msgid "Skip some safety checks during startup. This can speed up startup, but it may hide problems with files, permissions, or system settings."
msgstr "Пропустить часть проверок безопасности при запуске. Это ускоряет старт, но может скрыть проблемы с файлами, правами доступа или настройками системы."

#: htdocs/luci-static/resources/view/justclash/service.js:67
msgid "Start time sync service:"
msgstr "Синхронизация времени:"

#: htdocs/luci-static/resources/view/justclash/service.js:68
msgid "Start the built-in ntpd daemon so the system clock stays correct for secure connections. Without correct time, secure downloads and API connections may fail."
msgstr "Синхронизировать время, чтобы защищённые соединения работали корректно. При неверном времени могут не работать безопасные загрузки и API-подключения."

#: htdocs/luci-static/resources/view/justclash/service.js:72
msgid "GOMEMLIMIT (Memory limit):"
msgstr "GOMEMLIMIT (Лимит памяти):"

#: htdocs/luci-static/resources/view/justclash/service.js:76
msgid "Limit the Go garbage collector memory usage (in MiB). Select a predefined limit or 0 to disable."
msgstr "Ограничить использование памяти сборщиком мусора Go (в МиБ). Выберите предустановленный лимит или 0 для отключения."

#: htdocs/luci-static/resources/view/justclash/service.js:82
msgid "Storage"
msgstr "Хранилище"

#: htdocs/luci-static/resources/view/justclash/service.js:84
msgid "Store Mihomo external rules persistently:"
msgstr "Внешние правила Mihomo в хранилище:"

#: htdocs/luci-static/resources/view/justclash/service.js:85
msgid "Keep Mihomo external rule files in persistent router storage instead of temporary memory. Use this only if you need faster recovery after restart, because frequent writes can wear out built-in flash memory faster."
msgstr "Хранить файлы внешних правил Mihomo в постоянном хранилище роутера вместо временной памяти. Используйте это только если вам нужно более быстрое восстановление после перезапуска, потому что частые записи ускоряют износ встроенной flash-памяти."

#: htdocs/luci-static/resources/view/justclash/service.js:89
msgid "Store Mihomo cache persistently:"
msgstr "Кэш Mihomo в хранилище:"

#: htdocs/luci-static/resources/view/justclash/service.js:90
msgid "Keep Mihomo cache data such as selected groups and fake-IP mappings in persistent router storage instead of temporary memory. Use this only if you need it, because frequent writes can wear out built-in flash memory faster."
msgstr "Хранить данные кэша Mihomo, такие как выбранные группы и соответствия fake-IP, в постоянном хранилище роутера вместо временной памяти. Используйте это только при необходимости, потому что частые записи ускоряют износ встроенной flash-памяти."

#: htdocs/luci-static/resources/view/justclash/service.js:95
msgid "Traffic rules"
msgstr "Правила трафика"

#: htdocs/luci-static/resources/view/justclash/service.js:97
msgid "Change DNS settings at startup:"
msgstr "Менять DNS при запуске:"

#: htdocs/luci-static/resources/view/justclash/service.js:98
msgid "Update DNS settings automatically when the service starts. Use this if you want JustClash to manage dnsmasq DNS settings for you."
msgstr "Автоматически обновлять настройки DNS при запуске сервиса. Используйте это, если хотите, чтобы JustClash сам настраивал dnsmasq."

#: htdocs/luci-static/resources/view/justclash/service.js:102
msgid "Set traffic rules at startup:"
msgstr "Правила трафика при запуске:"

#: htdocs/luci-static/resources/view/justclash/service.js:103
msgid "Create traffic rules so client devices use the proxy. Disable this only if you already manage traffic redirection rules outside JustClash."
msgstr "Создавать правила, чтобы устройства в сети использовали прокси. Отключайте только если уже настраиваете перенаправление трафика вне JustClash."

#: htdocs/luci-static/resources/view/justclash/service.js:107
msgid "PBR priority:"
msgstr "Приоритет PBR:"

#: htdocs/luci-static/resources/view/justclash/service.js:108
msgid "Priority for the policy routing rule that sends marked traffic to the local TPROXY table. Lower numbers run earlier."
msgstr "Приоритет правила policy routing, которое отправляет помеченный трафик в локальную таблицу TPROXY. Чем меньше число, тем раньше срабатывает правило."

#: htdocs/luci-static/resources/view/justclash/service.js:118
msgid "Set router traffic rules at startup:"
msgstr "Правила трафика роутера при запуске:"

#: htdocs/luci-static/resources/view/justclash/service.js:119
msgid "Create traffic rules so the router's own traffic also uses the proxy. Enable this only if you want updates, package installs, and other router traffic to go through the proxy too."
msgstr "Создавать правила, чтобы трафик самого роутера тоже шёл через прокси. Включайте это только если хотите направлять через прокси обновления, установку пакетов и другой трафик роутера."

#: htdocs/luci-static/resources/view/justclash/service.js:123
msgid "Router socket owner exclusions:"
msgstr "Исключения по владельцу сокета роутера:"

#: htdocs/luci-static/resources/view/justclash/service.js:124
msgid "User names or numeric UIDs for router-originated sockets that should bypass proxy redirection rules. Useful for services like byedpi or https-dns-proxy that must reach the internet directly."
msgstr "Имена пользователей или числовые UID для сокетов, созданных самим роутером, которые должны обходить правила перенаправления через прокси. Полезно для сервисов вроде byedpi или https-dns-proxy, которым нужен прямой доступ в интернет."

#: htdocs/luci-static/resources/view/justclash/service.js:133
msgid "Router bypassed ports:"
msgstr "Исключенные порты роутера:"

#: htdocs/luci-static/resources/view/justclash/service.js:134
msgid "Destination ports (e.g., 22 or 80) for router traffic to bypass the proxy."
msgstr "Порты назначения (например, 22 или 80) для трафика роутера, которые будут идти в обход прокси."

#: htdocs/luci-static/resources/view/justclash/service.js:142
msgid "Client traffic interfaces:"
msgstr "Интерфейсы клиентского трафика:"

#: htdocs/luci-static/resources/view/justclash/service.js:150
msgid "Select which interfaces receive client traffic that should be processed by JustClash. This is usually your LAN bridge; do not select WAN unless you know exactly why."
msgstr "Выберите интерфейсы, через которые поступает клиентский трафик, который должен обрабатываться JustClash. Обычно это LAN-мост; не выбирайте WAN без точного понимания зачем."

#: htdocs/luci-static/resources/view/justclash/service.js:153
msgid "Client bypassed ports:"
msgstr "Исключенные порты клиентов:"

#: htdocs/luci-static/resources/view/justclash/service.js:154
msgid "Destination ports (e.g., 22 or 80) for client traffic to bypass the proxy."
msgstr "Порты назначения (например, 22 или 80) для трафика клиентов, которые будут идти в обход прокси."

#: htdocs/luci-static/resources/view/justclash/service.js:161
msgid "Client QUIC traffic:"
msgstr "Клиентский QUIC:"

#: htdocs/luci-static/resources/view/justclash/service.js:162
msgid "Choose how to handle QUIC traffic from devices on the selected client traffic interfaces. The selected mode decides whether this traffic is redirected or blocked."
msgstr "Выберите, как обрабатывать QUIC-трафик устройств в сети. Выбранный режим определяет, будет ли этот трафик перенаправляться или блокироваться."

#: htdocs/luci-static/resources/view/justclash/service.js:171
msgid "Client DoT traffic:"
msgstr "Клиентский DoT:"

#: htdocs/luci-static/resources/view/justclash/service.js:172
msgid "Choose how to handle DoT traffic from devices on your network. The selected mode decides whether this traffic is redirected or blocked."
msgstr "Выберите, как обрабатывать DoT-трафик устройств в сети. Выбранный режим определяет, будет ли этот трафик перенаправляться или блокироваться."

#: htdocs/luci-static/resources/view/justclash/service.js:181
msgid "Client DoH traffic:"
msgstr "Клиентский DoH:"

#: htdocs/luci-static/resources/view/justclash/service.js:182
msgid "Choose how to handle DoH traffic from devices on your network to well-known DoH IPs. The selected mode decides whether this traffic is redirected or blocked."
msgstr "Выберите, как обрабатывать DoH-трафик к известным DoH-серверам от устройств в сети. Выбранный режим определяет, будет ли этот трафик перенаправляться или блокироваться."

#: htdocs/luci-static/resources/view/justclash/service.js:191
msgid "Client DoQ traffic:"
msgstr "Клиентский DoQ:"

#: htdocs/luci-static/resources/view/justclash/service.js:192
msgid "Choose how to handle DoQ traffic from devices on your network. The selected mode decides whether this traffic is redirected or blocked."
msgstr "Выберите, как обрабатывать DoQ-трафик устройств в сети. Выбранный режим определяет, будет ли этот трафик перенаправляться или блокироваться."

#: htdocs/luci-static/resources/view/justclash/service.js:201
msgid "Client NTP traffic:"
msgstr "Клиентский NTP:"

#: htdocs/luci-static/resources/view/justclash/service.js:202
msgid "Choose how to handle time sync requests from devices on your network. The selected mode decides whether these requests are redirected, bypassed, or blocked."
msgstr "Выберите, как обрабатывать запросы времени от устройств в сети. Выбранный режим определяет, будут ли эти запросы перенаправляться, обходить прокси или блокироваться."

#: htdocs/luci-static/resources/view/justclash/service.js:211
msgid "Router NTP traffic:"
msgstr "NTP-трафик роутера:"

#: htdocs/luci-static/resources/view/justclash/service.js:212
msgid "Choose how to handle time sync requests from the router itself. The selected mode decides whether these requests are redirected, bypassed, or blocked."
msgstr "Выберите, как обрабатывать запросы времени от самого роутера. Выбранный режим определяет, будут ли эти запросы перенаправляться, обходить прокси или блокироваться."

#: htdocs/luci-static/resources/view/justclash/service.js:222
msgid "Scheduled tasks"
msgstr "Задачи по расписанию"

#: htdocs/luci-static/resources/view/justclash/service.js:224
msgid "Restart Mihomo automatically:"
msgstr "Автоперезапуск Mihomo:"

#: htdocs/luci-static/resources/view/justclash/service.js:225
msgid "Restart Mihomo on a schedule, for example once a week or once a day."
msgstr "Перезапускать Mihomo по расписанию, например раз в день или раз в неделю."

#: htdocs/luci-static/resources/view/justclash/service.js:229
msgid "Restart schedule:"
msgstr "Расписание перезапуска:"

#: htdocs/luci-static/resources/view/justclash/service.js:235
msgid "Use cron format to choose when Mihomo should restart automatically."
msgstr "Используйте формат cron, чтобы указать время автоматического перезапуска Mihomo."

#: htdocs/luci-static/resources/view/justclash/service.js:237
msgid "Invalid schedule format. Use: 'minute hour day month weekday' (for example, '0 3 * * 0')"
msgstr "Неверный формат расписания. Используйте: 'minute hour day month weekday' (например, '0 3 * * 0')"

#: htdocs/luci-static/resources/view/justclash/service.js:241
msgid "External resources"
msgstr "Внешние ресурсы"

#: htdocs/luci-static/resources/view/justclash/service.js:243
msgid "Core update source:"
msgstr "Источник ядра:"

#: htdocs/luci-static/resources/view/justclash/service.js:244
msgid "Github"
msgstr "Github"

#: htdocs/luci-static/resources/view/justclash/service.js:245
msgid "Custom URL"
msgstr "Пользовательский URL"

#: htdocs/luci-static/resources/view/justclash/service.js:246
msgid "Choose where Mihomo core should be downloaded from. 'Github' will automatically fetch the latest release, 'Custom URL' allows downloading directly from your specified link."
msgstr "Выберите, откуда загружать ядро Mihomo. 'Github' автоматически загрузит последний релиз, 'Custom URL' позволяет загружать напрямую по вашей ссылке."

#: htdocs/luci-static/resources/view/justclash/service.js:251
msgid "GitHub repository:"
msgstr "Репозиторий GitHub:"

#: htdocs/luci-static/resources/view/justclash/service.js:252
msgid "GitHub repository for Mihomo core updates. Must be in the format 'username/repo'. Example: 'MetaCubeX/mihomo'."
msgstr "Репозиторий GitHub для обновлений ядра Mihomo. Формат: 'пользователь/репозиторий'. Пример: 'MetaCubeX/mihomo'."

#: htdocs/luci-static/resources/view/justclash/service.js:259
msgid "Update channel:"
msgstr "Канал обновлений:"

#: htdocs/luci-static/resources/view/justclash/service.js:263
msgid "Choose which release channel to use for automatic Mihomo updates. Stable is safer, while newer channels may include newer features and newer bugs."
msgstr "Выберите канал для автоматических обновлений Mihomo. Стабильный канал безопаснее, а более новые каналы могут содержать и новые функции, и новые ошибки."

#: htdocs/luci-static/resources/view/justclash/service.js:269
msgid "Custom core base URL:"
msgstr "Пользовательский базовый URL ядра:"

#: htdocs/luci-static/resources/view/justclash/service.js:270
msgid "Base URL of the server hosting the core files (similar to GitHub releases). The server MUST contain a 'version.txt' file and the corresponding 'mihomo-linux-arch-version.gz' archives. Example: 'https://example.com/mihomo/'"
msgstr "Базовый URL сервера с файлами ядра. На сервере ДОЛЖНЫ быть файл 'version.txt' и архивы 'mihomo-linux-arch-version.gz'. Пример: 'https://example.com/mihomo/'"

#: htdocs/luci-static/resources/view/justclash/service.js:279
msgid "Rulesets download URL:"
msgstr "URL для загрузки наборов правил:"

#: htdocs/luci-static/resources/view/justclash/service.js:280
msgid "URL to download inbuild rulesets from. Leave empty to use the default."
msgstr "URL для скачивания встроенных наборов правил. Оставьте пустым, чтобы использовать по умолчанию."

#: htdocs/luci-static/resources/view/justclash/service.js:286
msgid "Zashboard download URL:"
msgstr "URL для загрузки Zashboard:"

#: htdocs/luci-static/resources/view/justclash/service.js:287
msgid "URL to download Zashboard dashboard from. Leave empty to use the default."
msgstr "URL для загрузки панели Zashboard. Оставьте пустым для использования по умолчанию."

#: htdocs/luci-static/resources/view/justclash/service.js:293
msgid "Metacubexd download URL:"
msgstr "URL для загрузки Metacubexd:"

#: htdocs/luci-static/resources/view/justclash/service.js:294
msgid "URL to download Metacubexd dashboard from. Leave empty to use the default."
msgstr "URL для загрузки панели Metacubexd. Оставьте пустым для использования по умолчанию."

#: htdocs/luci-static/resources/view/justclash/service.js:300
