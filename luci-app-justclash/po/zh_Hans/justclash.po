msgid "Download lists through:"
msgstr "通过以下方式下载列表："

#: htdocs/luci-static/resources/view/justclash/routing.js:639 htdocs/luci-static/resources/view/justclash/routing.js:689
msgid "Choose which proxy or group should be used when downloading these lists from the internet."
msgstr "选择从互联网下载这些列表时使用的代理或代理组。"

#: htdocs/luci-static/resources/view/justclash/routing.js:654
msgid "Traffic to domains matching this suffix will bypass the proxy (example: google.com)."
msgstr "匹配此域名后缀的流量将绕过代理（示例：google.com）。"

#: htdocs/luci-static/resources/view/justclash/routing.js:663
msgid "Traffic from this local IPv4 address or subnet will bypass the proxy (example: 192.168.31.212/32)."
msgstr "来自此本地 IPv4 地址或子网的流量将绕过代理（示例：192.168.31.212/32）。"

#: htdocs/luci-static/resources/view/justclash/routing.js:670
msgid "Traffic to this IPv4 address or subnet will bypass the proxy (example: 1.1.1.1/32)."
msgstr "到此 IPv4 地址或子网的流量将绕过代理（示例：1.1.1.1/32）。"

#: htdocs/luci-static/resources/view/justclash/routing.js:676
msgid "Block rules:"
msgstr "阻止规则："

#: htdocs/luci-static/resources/view/justclash/routing.js:676
msgid "Extra block rules. These are applied before proxy rules and groups, so matching traffic is stopped first."
msgstr "额外的阻止规则。它们优先于代理规则和代理组，匹配的流量将被优先阻止。"

#: htdocs/luci-static/resources/view/justclash/routing.js:686
msgid "Ready-made blocklists for ads and harmful sites. Matching traffic will be blocked. Choose the ones you want to use, or leave this empty."
msgstr "广告和恶意网站的预制阻止列表。匹配的流量将被阻止。可选择需要使用的列表，也可留空。"

#: htdocs/luci-static/resources/view/justclash/routing.js:704
msgid "Traffic to domains matching this suffix will be blocked (example: google.com)."
msgstr "匹配此域名后缀的流量将被阻止（示例：google.com）。"

#: htdocs/luci-static/resources/view/justclash/routing.js:713
msgid "Traffic to this IPv4 address or subnet will be blocked (example: 1.1.1.1/32)."
msgstr "到此 IPv4 地址或子网的流量将被阻止（示例：1.1.1.1/32）。"

#: htdocs/luci-static/resources/view/justclash/routing.js:719
msgid "Mihomo mixed port rule:"
msgstr "Mihomo 混合端口规则："

#: htdocs/luci-static/resources/view/justclash/routing.js:719
msgid "Extra settings for traffic that arrives through the Mihomo mixed port. Use this when that port should behave differently from the default route."
msgstr "针对通过 Mihomo 混合端口进入的流量的额外设置。当该端口需要与默认路由行为不同时时使用。"

#: htdocs/luci-static/resources/view/justclash/routing.js:725 htdocs/luci-static/resources/view/justclash/routing.js:744
msgid "Send traffic to:"
msgstr "将流量发送到："

#: htdocs/luci-static/resources/view/justclash/routing.js:725
msgid "Choose which proxy, group, or action handles traffic that comes in through the Mihomo mixed port."
msgstr "选择处理来自 Mihomo 混合端口流量的代理、代理组或动作。"

#: htdocs/luci-static/resources/view/justclash/routing.js:738
msgid "Default rule:"
msgstr "默认规则："

#: htdocs/luci-static/resources/view/justclash/routing.js:738
msgid "Used when no other rule matches. This is the fallback action for the remaining traffic."
msgstr "当没有其他规则匹配时使用。此规则作为剩余流量的兜底处理方式。"

#: htdocs/luci-static/resources/view/justclash/routing.js:744
msgid "Choose the fallback action for traffic that does not match any earlier rule."
msgstr "选择未匹配任何规则的流量应执行的兜底动作。"

#: htdocs/luci-static/resources/view/justclash/service.js:24
msgid "Service settings:"
msgstr "服务设置："

#: htdocs/luci-static/resources/view/justclash/service.js:24
msgid "Main service settings and scheduled tasks."
msgstr "主要服务设置与计划任务。"

#: htdocs/luci-static/resources/view/justclash/service.js:29
msgid "Delay startup after boot:"
msgstr "开机延迟启动："

#: htdocs/luci-static/resources/view/justclash/service.js:30
msgid "Start the service a little later after the router boots. Useful if the router needs extra time to bring up storage, WAN, or other services."
msgstr "在路由器启动后延迟一段时间再启动服务。如果路由器需要额外时间加载存储、WAN 或其他服务，这会很有用。"

#: htdocs/luci-static/resources/view/justclash/service.js:34
msgid "Startup delay:"
msgstr "启动延迟："

#: htdocs/luci-static/resources/view/justclash/service.js:44
msgid "Choose how many seconds to wait before the first service start after boot."
msgstr "选择开机后首次启动服务前需要等待的秒数。"

#: htdocs/luci-static/resources/view/justclash/service.js:46
msgid "Skip startup checks:"
msgstr "跳过启动检查："

#: htdocs/luci-static/resources/view/justclash/service.js:47
msgid "Skip some safety checks during startup. This can speed up startup, but it may hide problems with files, permissions, or system settings."
msgstr "跳过部分启动安全检查。可加快启动速度，但可能隐藏文件、权限或系统设置方面的问题。"

#: htdocs/luci-static/resources/view/justclash/service.js:51
msgid "Store Mihomo external rules persistently:"
msgstr "持久化存储 Mihomo 外部规则："

#: htdocs/luci-static/resources/view/justclash/service.js:52
msgid "Keep Mihomo external rule files in persistent router storage instead of temporary memory. Use this only if you need faster recovery after restart, because frequent writes can wear out built-in flash memory faster."
msgstr "将 Mihomo 外部规则文件存储在路由器的持久化存储中，而不是临时内存。仅在需要更快恢复时启用，因为频繁写入会加速闪存磨损。"

#: htdocs/luci-static/resources/view/justclash/service.js:56
msgid "Store Mihomo cache persistently:"
msgstr "持久化存储 Mihomo 缓存："

#: htdocs/luci-static/resources/view/justclash/service.js:57
msgid "Keep Mihomo cache data such as selected groups and fake-IP mappings in persistent router storage instead of temporary memory. Use this only if you need it, because frequent writes can wear out built-in flash memory faster."
msgstr "将 Mihomo 缓存（如选定的代理组、Fake-IP 映射等）存储在路由器持久化存储中。仅在确有需要时启用，因为频繁写入会加速闪存磨损。"

#: htdocs/luci-static/resources/view/justclash/service.js:61
msgid "Start time sync service:"
msgstr "启动时间同步服务："

#: htdocs/luci-static/resources/view/justclash/service.js:62
msgid "Start the built-in ntpd daemon so the system clock stays correct for secure connections. Without correct time, secure downloads and API connections may fail."
msgstr "启动内置 ntpd 服务以保持系统时间准确。时间不正确可能导致安全下载和 API 连接失败。"

#: htdocs/luci-static/resources/view/justclash/service.js:66
msgid "Change DNS settings at startup:"
msgstr "启动时修改 DNS 设置："

#: htdocs/luci-static/resources/view/justclash/service.js:67
msgid "Update DNS settings automatically when the service starts. Use this if you want JustClash to manage dnsmasq DNS settings for you."
msgstr "服务启动时自动更新 DNS 设置。如果希望 JustClash 管理 dnsmasq 的 DNS 配置，可启用此项。"

#: htdocs/luci-static/resources/view/justclash/service.js:66
msgid "Set traffic rules at startup:"
msgstr "启动时设置流量规则："

#: htdocs/luci-static/resources/view/justclash/service.js:67
msgid "Create traffic rules so client devices use the proxy. Disable this only if you already manage traffic redirection rules outside JustClash."
msgstr "创建流量规则，使客户端设备使用代理。仅在你已自行管理流量重定向规则时禁用此项。"

#: htdocs/luci-static/resources/view/justclash/service.js:71
msgid "PBR priority:"
msgstr "策略路由优先级："

#: htdocs/luci-static/resources/view/justclash/service.js:72
msgid "Priority for the policy routing rule that sends marked traffic to the local TPROXY table. Lower numbers run earlier."
msgstr "将标记流量发送到本地 TPROXY 表的策略路由规则优先级。数字越小优先级越高。"

#: htdocs/luci-static/resources/view/justclash/service.js:71
msgid "Set router traffic rules at startup:"
msgstr "启动时设置路由器自身流量规则："

#: htdocs/luci-static/resources/view/justclash/service.js:72
msgid "Create traffic rules so the router's own traffic also uses the proxy. Enable this only if you want updates, package installs, and other router traffic to go through the proxy too."
msgstr "创建规则使路由器自身流量也使用代理。仅在你希望路由器更新、安装软件包等流量也走代理时启用。"

#: htdocs/luci-static/resources/view/justclash/service.js:77
msgid "Client traffic interface:"
msgstr "客户端流量接口："

#: htdocs/luci-static/resources/view/justclash/service.js:77
msgid "Select which network interface client traffic comes from. This is usually your LAN bridge; do not select WAN unless you know exactly why."
msgstr "选择客户端流量来源的网络接口。通常为 LAN 网桥；除非明确知道用途，否则不要选择 WAN。"

#: htdocs/luci-static/resources/view/justclash/service.js:103
msgid "Client QUIC traffic:"
msgstr "客户端 QUIC 流量："

#: htdocs/luci-static/resources/view/justclash/service.js:104
msgid "Choose how to handle QUIC traffic from devices on the selected client traffic interfaces. The selected mode decides whether this traffic is redirected, bypassed, or blocked."
msgstr "选择如何处理来自客户端接口的 QUIC 流量。所选模式决定流量是被重定向、绕过还是阻止。"

#: htdocs/luci-static/resources/view/justclash/service.js:113
msgid "Client DoT traffic:"
msgstr "客户端 DoT 流量："

#: htdocs/luci-static/resources/view/justclash/service.js:114
msgid "Choose how to handle DoT traffic from devices on your network. The selected mode decides whether this traffic is redirected, bypassed, or blocked."
msgstr "选择如何处理网络中设备的 DoT 流量。所选模式决定流量是被重定向、绕过还是阻止。"

#: htdocs/luci-static/resources/view/justclash/service.js:123
msgid "Client DoQ traffic:"
msgstr "客户端 DoQ 流量："

#: htdocs/luci-static/resources/view/justclash/service.js:124
msgid "Choose how to handle DoQ traffic from devices on your network. The selected mode decides whether this traffic is redirected, bypassed, or blocked."
msgstr "选择如何处理网络中设备的 DoQ 流量。所选模式决定流量是被重定向、绕过还是阻止。"

#: htdocs/luci-static/resources/view/justclash/service.js:133
msgid "Client NTP traffic:"
msgstr "客户端 NTP 流量："

#: htdocs/luci-static/resources/view/justclash/service.js:134
msgid "Choose how to handle time sync requests from devices on your network. The selected mode decides whether these requests are redirected, bypassed, or blocked."
msgstr "选择如何处理网络中设备的时间同步请求。所选模式决定请求是被重定向、绕过还是阻止。"

#: htdocs/luci-static/resources/view/justclash/service.js:143
msgid "Router NTP traffic:"
msgstr "路由器 NTP 流量："

#: htdocs/luci-static/resources/view/justclash/service.js:144
msgid "Choose how to handle time sync requests from the router itself. The selected mode decides whether these requests are redirected, bypassed, or blocked."
msgstr "选择如何处理路由器自身的时间同步请求。所选模式决定请求是被重定向、绕过还是阻止。"

#: htdocs/luci-static/resources/view/justclash/service.js:154
msgid "Scheduled tasks"
msgstr "计划任务"

#: htdocs/luci-static/resources/view/justclash/service.js:156
msgid "Restart Mihomo automatically:"
msgstr "自动重启 Mihomo："

#: htdocs/luci-static/resources/view/justclash/service.js:157
msgid "Restart Mihomo on a schedule, for example once a week or once a day."
msgstr "按计划自动重启 Mihomo，例如每周一次或每天一次。"

#: htdocs/luci-static/resources/view/justclash/service.js:161
msgid "Update Mihomo automatically:"
msgstr "自动更新 Mihomo："

#: htdocs/luci-static/resources/view/justclash/service.js:165
msgid "Choose whether Mihomo should update automatically, and under what conditions."
msgstr "选择是否自动更新 Mihomo，以及在什么条件下更新。"

#: htdocs/luci-static/resources/view/justclash/service.js:169
msgid "Update channel:"
msgstr "更新通道："

#: htdocs/luci-static/resources/view/justclash/service.js:173
msgid "Choose which release channel to use for automatic Mihomo updates. Stable is safer, while newer channels may include newer features and newer bugs."
msgstr "选择用于自动更新 Mihomo 的发布通道。Stable 更稳定，而较新的通道可能包含新功能，也可能带来新问题。"

#: htdocs/luci-static/resources/view/justclash/service.js:177
msgid "Restart schedule:"
msgstr "重启计划："

#: htdocs/luci-static/resources/view/justclash/service.js:181
msgid "Use cron format to choose when Mihomo should restart automatically."
msgstr "使用 cron 格式选择 Mihomo 自动重启的时间。"

#: htdocs/luci-static/resources/view/justclash/service.js:183 htdocs/luci-static/resources/view/justclash/service.js:192
msgid "Invalid schedule format. Use: 'minute hour day month weekday' (for example, '0 3 * * 0')"
msgstr "计划格式无效。格式应为：分钟 小时 日期 月份 星期（例如：0 3 * * 0）"

#: htdocs/luci-static/resources/view/justclash/service.js:186
