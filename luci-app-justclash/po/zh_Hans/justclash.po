#: htdocs/luci-static/resources/view/justclash/proxy.js:44
msgid "Logging level:"
msgstr "日志级别:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:48
msgid "Choose how much information Mihomo writes to the log. Higher levels help with debugging, but create more log entries."
msgstr "选择 Mihomo 写入日志的信息量。较高级别有助于调试，但会创建更多日志条目。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:52
msgid "Bind all outbound connections to interface:"
msgstr "绑定所有出站连接到接口:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:53
msgid "Bind Mihomo outbound connections to a specific network device by default. Leave empty to let the system choose the outgoing interface. Per-proxy and per-provider interface settings should override this value when set."
msgstr "默认将 Mihomo 出站连接绑定到特定网络设备。留空则由系统选择输出接口。每个代理和每个提供商的接口设置将覆盖此值（如果已设置）。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:61
msgid "Transparent proxy port:"
msgstr "透明代理端口:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:62
msgid "Port used for redirected TCP/UDP traffic. Change it only if this port is already used by another service."
msgstr "用于重定向的 TCP/UDP 流量的端口。仅在此端口已被其他服务占用时才更改它。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:68
msgid "Enable Mihomo mixed port:"
msgstr "启用 Mihomo 混合端口:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:69
msgid "Use the Mihomo mixed port so one port handles both HTTP(S) and SOCKS5 connections. This is useful when apps or devices connect to the router as a regular proxy."
msgstr "使用 Mihomo 混合端口，这样一个端口可以同时处理 HTTP(S) 和 SOCKS5 连接。这在应用或设备将路由器作为常规代理连接时非常有用。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:73
msgid "Mihomo mixed port:"
msgstr "Mihomo 混合端口:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:74
msgid "Port used by the Mihomo mixed port listener for both HTTP(S) and SOCKS5 connections from apps and devices on your network."
msgstr "Mihomo 混合端口监听器使用的端口，用于处理网络中应用和设备的 HTTP(S) 和 SOCKS5 连接。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:82
msgid "Mixed port authentication:"
msgstr "混合端口身份验证:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:83
msgid "Require username and password for access to the Mihomo mixed port. Add one entry per line in the format user:pass."
msgstr "需要用户名和密码才能访问 Mihomo 混合端口。每行添加一个条目，格式为 user:pass。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:92
msgid "Unified delay:"
msgstr "统一延迟 (Unified delay):"

#: htdocs/luci-static/resources/view/justclash/proxy.js:93
msgid "Use the same delay value when checking response time, so test results stay more consistent."
msgstr "在检查响应时间时使用相同的延迟值，这样测试结果会更加一致。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:97
msgid "Try TCP connections in parallel:"
msgstr "并行尝试 TCP 连接:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:98
msgid "Try several TCP connections at the same time. This can help on unstable networks, but it may create extra connection attempts."
msgstr "同时尝试多个 TCP 连接。这在不稳定的网络上可能会有帮助，但可能会产生额外的连接尝试。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:102
msgid "Client profile for all connections:"
msgstr "所有连接的客户端配置:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:106
msgid "How the client identifies itself for supported protocols. Leave the default unless your provider expects a specific profile."
msgstr "客户端在受支持协议中的身份标识方式。除非提供商要求特定的配置文件，否则请保留默认值。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:110
msgid "User-Agent for downloads:"
msgstr "下载的 User-Agent:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:111
msgid "User-Agent sent when downloading external files such as subscriptions or rule lists."
msgstr "下载订阅或规则列表等外部文件时发送的 User-Agent。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:115
msgid "Check whether files changed:"
msgstr "检查文件是否更改:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:116
msgid "Only download external files again when the server says they changed. This saves bandwidth and avoids unnecessary updates."
msgstr "仅在服务器表示外部文件发生更改时重新下载。这可以节省带宽并避免不必要的更新。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:120
msgid "Idle time before connection check:"
msgstr "连接检查前的空闲时间:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:121
msgid "How long to wait with no activity before checking whether the connection is still alive. Shorter values detect dead connections sooner."
msgstr "在检查连接是否仍然存活之前等待无活动的时间。较短的值能更快检测到死连接。"

#: htdocs/luci-static/resources/view/justclash/proxy.js:132
msgid "Connection check interval:"
msgstr "连接检查间隔:"

#: htdocs/luci-static/resources/view/justclash/proxy.js:133
msgid "How often to repeat that check after the connection becomes idle."
msgstr "连接处于空闲状态后，多久重复一次该检查。"

