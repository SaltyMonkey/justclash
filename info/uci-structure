# Example UCI structure for sections and fields exposed in LuCI.
# This is a compact reference, not a copy of the shipped default config.

config main 'settings'
    option delayed_boot                   '0'
    option delayed_boot_value             '10'
    option skip_environment_checks        '0'
    option mihomo_persistent_ext_rules    '0'
    option mihomo_persistent_cache        '0'
    option ntpd_start                     '1'
    option dnsmasq_apply_changes          '1'
    option nft_apply_changes              '1'
    option pbr_priority                   '169'
    option nft_apply_changes_router       '0'
    list   nft_dscp_exclude_router        'cs1'
    list   tproxy_input_interfaces        'br-lan'
    option nft_quic_mode                  'DROP'
    option nft_dot_mode                   'BY RULES'
    option nft_dot_quic_mode              'BY RULES'
    option nft_ntp_mode                   'BY RULES'
    option nft_ntp_mode_router            'DIRECT'
    option mihomo_autorestart             '0'
    option mihomo_cron_autorestart_string '0 5 * * 0'
    option mihomo_autoupdate              'no'
    option mihomo_autoupdate_channel      'stable'
    option mihomo_cron_update_string      '0 5 * * 0'

config proxy 'proxy'
    option controller_bind_interface      'lan'
    option use_dashboard                  '0'
    option dashboard_repo                 'metacubexd'
    option api_password                   'changeme'
    option log_level                      'warning'
    option interface_name                 'eth0'
    option tproxy_port                    '7893'
    option use_mixed_port                 '0'
    option mixed_port                     '7892'
    list   proxy_authentication           'user1:pass1'
    list   proxy_authentication           'user2:pass2'
    option unified_delay                  '1'
    option tcp_concurrent                 '1'
    option global_client_fingerprint      'random'
    option global_ua                      'Mozilla/5.0 (...)'
    option etag_support                   '1'
    option keep_alive_idle                '15'
    option keep_alive_interval            '15'
    option profile_store_selected         '1'
    option profile_store_fake_ip          '1'
    option dns_listen_port                '7894'
    option use_system_hosts               '0'
    option dns_cache_max_size             '2048'
    option fake_ip_filter_mode            'whitelist'
    option fake_ip_range                  '198.18.0.1/16'
    option fake_ip_ttl                    '1'
    list   nameserver_policy              '+.example.org/1.1.1.1'
    list   default_nameserver             '1.1.1.1'
    list   direct_nameserver              'tls://dns.example.org'
    list   proxy_server_nameserver        'https://dns.google/dns-query'
    list   nameserver                     'https://1.1.1.1/dns-query'
    list   fake_ip_include_domains        '+.example.org'
    list   fake_ip_exclude_domains        '+.lan'
    option sniffer_enable                 '1'
    option sniffer_parse_pure_ip          '1'
    list   sniffer_exclude_domain         '+.lan'
    list   sniffer_force_domain           '+.example.org'
    list   sniffer_skip_src_address       '192.168.1.0/24'
    list   sniffer_skip_dst_address       '8.8.8.8/32'
    option core_ntp_enabled               '1'
    option core_ntp_server                '194.190.168.1'
    option core_ntp_port                  '123'
    option core_ntp_interval              '300'
    option core_ntp_write_system          '0'

config proxies
    option enabled                        '1'
    option name                           'proxy1'
    option mode                           'uri'
    option proxy_link_object              '{"type":"ss","server":"1.2.3.4","port":12345}'
    option proxy_link_uri                 'ss://xxxxxxx...'
    option dialer_proxy                   'proxy2'
    option interface_name                 'eth0'
    list   enabled_list                   'rule_set_1'
    list   custom_enabled_domain_list     '/etc/justclash/domain-list.mrs'
    list   custom_enabled_cidr_list       '/etc/justclash/cidr-list.mrs'
    option use_proxy_for_list_update      '0'
    option list_update_interval           '43200'
    list   additional_domain_route        'google.com'
    list   additional_destip_route        '8.8.8.8/32'
    list   additional_srcip_route         '192.168.1.0/24'

config proxy_provider
    option enabled                        '1'
    option name                           'provider1'
    option subscription                   'https://example.com/subscription'
    option override_dialer_proxy          'proxy1'
    option override_interface_name        'eth0'
    option subscription_hwid_support      '0'
    option update_interval                '3600'
    option proxy                          'DIRECT'
    option health_check                   '1'
    option health_check_url               'https://www.google.com/generate_204'
    option health_check_expected_status   '204'
    option health_check_interval          '360'
    option health_check_timeout           '5000'
    option health_check_lazy              '1'
    option filter                         'HK|US|Netflix'
    option exclude_filter                 'CN|douyin'
    option exclude_type                   'vless|ss'

config proxy_group
    option enabled                        '1'
    option name                           'group1'
    # allowed values: fallback | load-balance | url-test
    option group_type                     'fallback'
    option strategy                       'consistent-hashing'
    list   proxies                        'proxy1'
    list   providers                      'provider1'
    option check_url                      'https://www.google.com/generate_204'
    option expected_status                '204'
    option check_interval                 '180'
    option tolerance                      '50'
    option check_timeout                  '5000'
    option max_failed_times               '5'
    option lazy                           '1'
    option filter                         'HK|US|Netflix'
    option exclude_filter                 'CN|douyin'
    option exclude_type                   'vless|ss'
    list   enabled_list                   'rule_set_1'
    list   custom_enabled_domain_list     '/etc/justclash/domain-list.mrs'
    list   custom_enabled_cidr_list       '/etc/justclash/cidr-list.mrs'
    option use_proxy_group_for_list_update '0'
    option list_update_interval           '43200'
    list   additional_domain_route        'google.com'
    list   additional_destip_route        '8.8.8.8/32'
    list   additional_srcip_route         '192.168.1.0/24'

config direct_rules 'direct_rules'
    list   enabled_list                   'rule_set_2'
    list   custom_enabled_domain_list     '/etc/justclash/direct-domain-list.mrs'
    list   custom_enabled_cidr_list       '/etc/justclash/direct-cidr-list.mrs'
    option list_update_interval           '43200'
    option proxy                          'DIRECT'
    list   additional_domain_direct       'example.com'
    list   additional_srcip_direct        '192.168.2.0/24'
    list   additional_destip_direct       '8.8.4.4/32'

config block_rules 'block_rules'
    list   enabled_blocklist              'block_list1'
    option proxy                          'DIRECT'
    list   additional_domain_blockroute   'ads.example.com'
    list   additional_destip_blockroute   '2.2.2.2/32'

config mixed_port_rules 'mixed_port_rules'
    option exit_rule                      'BY RULES'

config final_rules 'final_rules'
    option exit_rule                      'DIRECT'
