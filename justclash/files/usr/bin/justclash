# List of NTP server IP addresses:
DEFAULT_NTP_IPS="194.190.168.1 89.109.251.22 89.109.251.23 216.239.35.4 216.239.35.8"

DEFAULT_EXTERNAL_PANEL="metacubexd"
DEFAULT_RULESET_PROXY_DIRECT_SECTION="DIRECT"
