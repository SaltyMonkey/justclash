config main 'settings'
    option wait_for_wan '0'
    option wait_for_wan_max '90'
    option delayed_boot '0'
    option delayed_boot_value '10'
    option skip_environment_checks '0'
    option mihomo_persistent_ext_rules '0'
    option mihomo_persistent_cache '0'
    option ntpd_start '0'
    option mihomo_mem_limit '0'
    option dnsmasq_apply_changes '1'
    option nft_apply_changes '1'
    option pbr_priority '169'
    option nft_apply_changes_router '1'
    option nft_quic_mode 'REJECT'
    option nft_dot_mode 'BY RULES'
    option nft_doh_mode 'BY RULES'
    option nft_dot_quic_mode 'BY RULES'
    option nft_ntp_mode 'BY RULES'
    option nft_ntp_mode_router 'BY RULES'
    option tproxy_input_interfaces 'br-lan'
    list nft_ports_exclude '6881'
    option mihomo_core_source_type 'github'
    option mihomo_github_repo 'MetaCubeX/mihomo'
    option mihomo_github_channel 'stable'
    option mihomo_custom_core_url ''
    option mihomo_rulesets_files_download_url 'https://cdn.jsdelivr.net/gh/saltymonkey/mrs-parsed-data'
    option mihomo_dashboard_zashboard_url 'https://github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip'
    option mihomo_dashboard_metacubexd_url 'https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip'
    option mihomo_dashboard_yacd_meta_url 'https://github.com/MetaCubeX/Yacd-meta/archive/refs/heads/gh-pages.zip'
    option mihomo_geosite_url 'https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geosite.dat'
    option mihomo_geoip_url 'https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geoip.dat'
    option mihomo_autorestart '0'
    option mihomo_cron_autorestart_string '0 5 * * 0'
    option mihomo_service_data_autoupdate '0'
    option mihomo_cron_service_data_update_string '0 4 * * 0'
    option mihomo_scheduled_work '0'
    option mihomo_cron_scheduled_work_start_string '0 5 * * *'
    option mihomo_cron_scheduled_work_stop_string '0 23 * * *'

config proxy 'proxy'
    option controller_bind_interface 'lan'
    option use_dashboard '0'
    option dashboard_repo 'metacubexd'
    option api_password 'abcdefghijklmnopqrstuvwxyz1234567890'
    option api_tls '0'
    option api_tls_cert '/etc/uhttpd.crt'
    option api_tls_key '/etc/uhttpd.key'
    option log_level 'warning'
    option tproxy_port '7893'
    option use_mixed_port '0'
    option mixed_port '1080'
    option unified_delay '1'
    option tcp_concurrent '1'
    option geodata_mode '0'
    option geodata_autoupdate '0'
    option geodata_autoupdate_interval '24'
    option global_ua 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/150.0.0.0 Safari/537.36'
    option etag_support '1'
    option keep_alive_idle '15'
    option keep_alive_interval '15'
    option profile_store_selected '1'
    option profile_store_fake_ip '1'
    option core_ntp_enabled '1'
    option core_ntp_server '194.190.168.1'
    option core_ntp_port '123'
    option core_ntp_interval '60'
    option core_ntp_write_system '1'
    option dns_listen_port '7894'
    option dns_cache_max_size '2048'
    option use_system_hosts '0'
    option fake_ip_range '198.18.0.1/16'
    option fake_ip_ttl '60'
    list nameserver_policy '+.cbr.ru/195.208.4.1'
    list nameserver_policy '+.fsb.ru/195.208.4.1'
    list nameserver_policy '+.fsrar.ru/195.208.4.1'
